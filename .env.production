# ── WebinarPulse Production Environment ──
# Скопируйте этот файл в .env на сервере и заполните значения

# PostgreSQL (внутренний контейнер)
DB_USER=pulse
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=webinar_pulse

# JWT для авторизации дашборда
JWT_SECRET=CHANGE_ME_RANDOM_STRING_64_CHARS

# API-ключ для webhook-эндпоинтов (этот же ключ указать в n8n)
WEBHOOK_API_KEY=CHANGE_ME_WEBHOOK_SECRET
